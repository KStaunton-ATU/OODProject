<Window x:Class="OODProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OODProject"
        mc:Ignorable="d"
        Title="Media Player" Height="600" Width="900"
        Background="#1E1E1E" Focusable="true" Loaded="Window_Loaded" PreviewKeyDown="Window_PreviewKeyDown">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="120" />
        </Grid.RowDefinitions>

        <Border Grid.Column="0" Grid.Row="0" Background="Black" CornerRadius="6">
            <MediaElement Name="Player" LoadedBehavior="Manual" UnloadedBehavior="Stop" Stretch="Uniform" 
                          MediaOpened="Player_MediaOpened" MediaEnded="Player_MediaEnded" MediaFailed="Player_MediaFailed" />
        </Border>

        <Border Grid.Column="1" Grid.Row="0" Background="#2A2A2A" CornerRadius="6" Padding="10">
            <StackPanel>
                <TextBlock Text="Playlist" FontSize="20" Foreground="White" Margin="0 0 0 10" />

                <ListBox Name="PlaylistListBox" SelectionChanged="PlaylistListBox_SelectionChanged" Background="#333" BorderThickness="0" Foreground="White">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8" Margin="0 4" Background="#444" CornerRadius="4">
                                <TextBlock Text="{Binding Title}" />
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <StackPanel Grid.Column="0" Grid.Row="1" Orientation="Vertical" Margin="0 10 0 0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 10">
                <Slider x:Name="VolumeSlider" Minimum="0" Maximum="1" Value="1" Width="100" ValueChanged="VolumeSlider_ValueChanged" Height="22" PreviewMouseDown="VolumeSlider_PreviewMouseDown"/>
                <ToggleButton x:Name="btnShuffle" Content="Shuffle" Width="80" Height="30" Margin="10" Checked="btnShuffle_Checked" Unchecked="btnShuffle_Unchecked"/>
                <Button x:Name="btnLoop" Content="🔁" Width="50" Height="40" Margin="5" Click="btnLoop_Click" />
                <Button x:Name="btnRewind" Content="⏪" Width="50" Height="40" Margin="5" Click="btnRewind_Click" />
                <Button x:Name="btnPlay" Content="▶" Width="50" Height="40" Margin="5" Click="btnPlay_Click" />
                <Button x:Name="btnPause" Content="⏸" Width="50" Height="40" Margin="5" Click="btnPause_Click" />
                <Button x:Name="btnFastForward" Content="⏩" Width="50" Height="40" Margin="5" Click="btnFastForward_Click" />
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Slider Name="SeekBar" Minimum="0" Maximum="100" Value="0" Grid.Column="0" Margin="10 0" 
                        ValueChanged="SeekBar_ValueChanged" PreviewMouseDown="SeekBar_PreviewMouseDown" PreviewMouseUp="SeekBar_PreviewMouseUp" />

                <TextBlock Name="Timestamp" Text="0:00" Foreground="White" VerticalAlignment="Center" Margin="10 0" Grid.Column="1" />
            </Grid>
        </StackPanel>
        <Button x:Name="btn_openFile" Grid.Column="1" Content="Open File"  Margin="10,20,141,0" Grid.Row="1" VerticalAlignment="Top" Height="30" Width="100" Click="btn_openFile_Click"/>
        <Button x:Name="btn_OpenPlaylist" Grid.Column="1" Content="Open PlayList"  Margin="141,20,10,0" Grid.Row="1" VerticalAlignment="Top" Height="30" Width="100" Click="btn_OpenPlaylist_Click"/>
        <Button x:Name="btnSaveFavorite" Content="Save As Favorite" Click="btnSaveFavorite_Click" Width="100" Height="30" Grid.Column="1" Margin="10,80,141,10" Grid.Row="1"/>
        <Button x:Name="btnLoadFavorites" Content="Load Favorites" Click="btnLoadFavorites_Click" Width="100" Height="30" Grid.Column="1" Margin="141,80,10,10" Grid.Row="1"/>
    </Grid>
</Window>
    
